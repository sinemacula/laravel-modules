{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "sinemacula/laravel-modules",
    "type": "library",
    "description": "A lightweight, convention-driven modular architecture package for Laravel - auto-discovers modules as directories with zero manifests, zero boilerplate, and nothing new to learn.",
    "keywords": [
        "sine macula",
        "laravel",
        "modules",
        "modular",
        "architecture"
    ],
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Ben Carey",
            "email": "bdmc@sinemacula.co.uk"
        }
    ],
    "require": {
        "php": "^8.3",
        "laravel/framework": "^13.0"
    },
    "require-dev": {
        "brianium/paratest": "^7.20",
        "doctrine/coding-standard": "^14.0",
        "friendsofphp/php-cs-fixer": "^3.94",
        "larastan/larastan": "^3.9",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^11.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpdoc-parser": "^2.3",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^12.5",
        "sinemacula/coding-standards": "dev-master",
        "slevomat/coding-standard": "^8.28",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "files": [
            "src/Support/helpers.php"
        ],
        "psr-4": {
            "SineMacula\\Laravel\\Modules\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "check": [
            "qlty check"
        ],
        "format": [
            "qlty fmt"
        ],
        "test": [
            "@php vendor/bin/paratest $@"
        ],
        "test-coverage": [
            "@php vendor/bin/paratest --coverage-clover=clover.xml"
        ]
    },
    "scripts-descriptions": {
        "check": "Run static analysis and lint checks via qlty.",
        "format": "Format codebase using qlty.",
        "test": "Run the default PHPUnit test suites in parallel using Paratest.",
        "test-coverage": "Shortcut to run Paratest coverage for default suites."
    },
    "extra": {
        "laravel": {
            "providers": [
                "SineMacula\\Laravel\\Modules\\Providers\\ModuleServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/sinemacula/coding-standards"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
